{
    // =========================
    // CMake Tools configuration
    // =========================

    // NOTE: cmake.buildDirectory, cmake.installPrefix, and testMate paths are NOT set here.
    // - On Windows host: CMake Tools defaults to ${workspaceFolder}/build, which is correct.
    // - In devcontainer: These are overridden to /tmp/build in .devcontainer/devcontainer.json
    //   because the Podman bind-mounted workspace may not reliably support executable artifacts.
    //   Workspace-folder settings (.vscode/settings.json) take precedence over devcontainer.json
    //   machine-level settings, so they must be omitted here for the override to work.

    // Automatically run CMake configure when opening the folder
    "cmake.configureOnOpen": true,

    // Generator to use for CMake (Ninja is fast and recommended)
    "cmake.generator": "Ninja", // Recommended: Ninja, can change to "Unix Makefiles" if needed

    // List of preferred generators for CMake
    "cmake.preferredGenerators": ["Ninja"],

    // Extra arguments to pass to CMake during configuration
    "cmake.configureArgs": [], // optional extra args for configuration

    // Extra arguments to pass to CMake during build
    "cmake.buildArgs": [], // optional extra args for build

    // Number of parallel jobs for building
    "cmake.parallelJobs": 0, // auto-detect number of CPU cores

    // Debugger configuration for CMake Tools
    "cmake.debugConfig": {
        "MIMode": "gdb", // Debugger mode (gdb for GNU Debugger)
        "miDebuggerPath": "/usr/bin/gdb" // Path to gdb executable
    },

    // =========================
    // Dev Containers (Podman)
    // =========================

    // Use Podman instead of Docker for Dev Containers
    "dev.containers.dockerPath": "podman"
}
