// For format details, see https://aka.ms/devcontainer.json
{
    "name": "C++",
    "build": {
        "dockerfile": "Dockerfile"
    },
    
    "remoteEnv": {
        "PODMAN_USERNS": "keep-id", // Podman-specific settings for Dev Containers
        // Centralized build directory — single source of truth.
        // If you change this path, update it in 3 places below:
        //   1. cmake.buildDirectory / cmake.installPrefix
        //   2. testMate.cpp.test.advancedExecutables patterns
        //   3. postCreateCommand
        // Each workspace folder gets its own subdirectory via ${workspaceFolderBasename} (VS Code)
        // or ${workspaceName} (TestMate) to prevent collisions in a multi-root workspace.
        "BUILD_ROOT": "/tmp/build"
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "mhutchie.git-graph",
                "eamodio.gitlens",
                "github.vscode-pull-request-github",
                "hediet.vscode-drawio",

                // C++ tooling
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cmake-tools",
                "cheshirekow.cmake-format",

                // Test Explorer + TestMate
                // Test Explorer + TestMate
                // In version 1.59, VS Code added an official API and UI for running tests, which provides all
                // the functionality of this extension and more. Therefore "hbenl.vscode-test-explorer" extension is now deprecated.
                //"hbenl.vscode-test-explorer",
                "matepek.vscode-catch2-test-adapter",
                "jacqueslucke.gcov-viewer",

                // Python
                "ms-python.python",
                "LittleFoxTeam.vscode-python-test-adapter",

                "google.geminicodeassist"
            ],
            "settings": {
                "files.eol": "\n",
                "cmake.enableCTest": false,
                // Build path — keep in sync with remoteEnv.BUILD_ROOT above.
                // ${workspaceFolderBasename} ensures each workspace folder in a
                // multi-root workspace gets its own isolated build tree.
                "cmake.buildDirectory": "/tmp/build/${workspaceFolderBasename}",
                "cmake.installPrefix": "/tmp/build/${workspaceFolderBasename}/install",
                "testMate.cpp.test.advancedExecutables": [
                    // Out-of-source builds (cmake.buildDirectory → /tmp/build/)
                    {
                        "pattern": "/tmp/build/workspace/**/tests/*",
                        "name": "workspace: ${baseFilename}"
                    },
                    {
                        "pattern": "/tmp/build/workspace1/**/tests/*",
                        "name": "workspace1: ${baseFilename}"
                    },
                    {
                        "pattern": "/tmp/build/workspace2/**/tests/*",
                        "name": "workspace2: ${baseFilename}"
                    },
                    // In-tree builds (/workspace/**/build/)
                    {
                        "pattern": "/workspace/build/**/tests/*",
                        "name": "workspace: ${baseFilename}"
                    },
                    {
                        "pattern": "/workspace/workspace1/build/**/tests/*",
                        "name": "workspace1: ${baseFilename}"
                    },
                    {
                        "pattern": "/workspace/workspace2/build/**/tests/*",
                        "name": "workspace2: ${baseFilename}"
                    }
                ],

                // Python — interpreter points to the venv where pytest is installed.
                // Set here (not in workspace settings.json) because the path is container-specific.
                "python.defaultInterpreterPath": "/opt/venv/bin/python",
                "pythonTestExplorer.testFramework": "pytest"
            }
        }
    },

    "runArgs": [
        "--privileged",
        "--device=/dev/bus/usb:/dev/bus/usb"
    ],

    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "workspaceFolder": "/workspace",

    // Ensure build dir exists — keep in sync with remoteEnv.BUILD_ROOT above.
    "postCreateCommand": "mkdir -p /tmp/build",

    "remoteUser": "vscode",
    "containerUser": "vscode"
}
